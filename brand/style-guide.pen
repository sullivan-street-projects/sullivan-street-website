        {
          "type": "frame",
          "id": "OWqXu",
          "name": "Usage Rules",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 24,
          "children": [
            {
              "type": "text",
              "id": "yOZta",
              "name": "rulesLabel",
              "fill": "#999999",
              "content": "USAGE RULES",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "500",
              "letterSpacing": 3
            },
            {
              "type": "frame",
              "id": "tUXFA",
              "name": "rulesCols",
              "width": "fill_container",
              "gap": 48,
              "children": [
                {
                  "type": "frame",
                  "id": "i6856",
                  "name": "doCol",
                  "width": "fill_container",
                  "fill": "#F0FAF0",
                  "cornerRadius": 8,
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "YT4lr",
                      "name": "doTitle",
                      "fill": "#22c55e",
                      "content": "Do",
                      "fontFamily": "Inter",
                      "fontSize": 18,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "KQC0Z",
                      "name": "do1",
                      "fill": "#1a1a1a",
                      "content": "• Use Libre Baskerville for headlines and the stacked wordmark",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "2sgkp",
                      "name": "do2",
                      "fill": "#1a1a1a",
                      "content": "• Use Instrument Sans for body copy, UI, labels, and navigation",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "CojRg",
                      "name": "do3",
                      "fill": "#1a1a1a",
                      "content": "• Apply grain overlay at exactly 5% opacity",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "F5WBX",
                      "name": "do4",
                      "fill": "#1a1a1a",
                      "content": "• Maintain charcoal-on-paper or paper-on-charcoal contrast",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "hwGXi",
                      "name": "do5new",
                      "fill": "#1a1a1a",
                      "content": "• Use generous whitespace — padding and margins should let content breathe",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "xbTPn",
                      "name": "do6new",
                      "fill": "#1a1a1a",
                      "content": "• Treat the logo as a logotype in Libre Baskerville — no graphical mark",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "FpxzB",
                      "name": "do5",
                      "fill": "#1a1a1a",
                      "content": "• Always pair the stacked wordmark with the tagline: GROWTH MARKETING PARTNERS",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "uLStV",
                      "name": "do6",
                      "fill": "#1a1a1a",
                      "content": "• Use design tokens from @theme — never hardcode hex",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "WaKAM",
                  "name": "dontCol",
                  "width": "fill_container",
                  "fill": "#FFF5F5",
                  "cornerRadius": 8,
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "d6sls",
                      "name": "dontTitle",
                      "fill": "#ef4444",
                      "content": "Don't",
                      "fontFamily": "Inter",
                      "fontSize": 18,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "cYUmT",
                      "name": "dont1",
                      "fill": "#1a1a1a",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "• Mix serif and sans arbitrarily — italic Libre Baskerville closers are the exception, not a free pass",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "NWU87",
                      "name": "dont2",
                      "fill": "#1a1a1a",
                      "content": "• Use colors outside the defined palette",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "h79Lt",
                      "name": "dont3",
                      "fill": "#1a1a1a",
                      "content": "• Alter letterSpacing on the stacked wordmark or tagline",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "jQD5m",
                      "name": "dont4",
                      "fill": "#1a1a1a",
                      "content": "• Stretch, rotate, or skew any logo lockup",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "YfPgS",
                      "name": "dont5",
                      "fill": "#1a1a1a",
                      "content": "• Separate the wordmark from its tagline in the stacked lockup",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "9wwG4",
                      "name": "dont6",
                      "fill": "#1a1a1a",
                      "content": "• Use \"Growth demands clarity\" as brand copy — it is not an approved tagline",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "qCpvd",
                      "name": "dont7",
                      "fill": "#1a1a1a",
                      "content": "• Use \"SSP\" in public-facing copy — it is for internal use only",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        },
