# HTTPS redirect
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Canonical host: www -> apex (matches the canonical tag)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Strip trailing slashes: /privacy-policy/ -> /privacy-policy (Astro
# trailingSlash 'never'). Without this the clean-URL rewrite below can't
# match ("$1/.html" never exists) and the server 500s.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]

# Rescue booking-intent clicks: a malformed (relative) TidyCal link exists in
# the wild — GA4 shows real users landing on this path and 404ing. 301 them
# to the actual booking page. (Found via ga.mjs pages report, 2026-07-15.)
RewriteRule ^sullivan-street-projects/growth-consultation/?$ https://tidycal.com/sullivan-street-projects/growth-consultation [L,R=301]

# Clean URLs: /privacy-policy -> privacy-policy.html (Astro build.format 'file')
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Real 404s (replaces the SPA catch-all)
ErrorDocument 404 /404.html

# Security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Fonts are self-hosted by Astro's Fonts API now — fonts.googleapis.com /
  # fonts.gstatic.com removed from style-src / font-src.
  # GA4 (googletagmanager.com / google-analytics.com) + Clarity (*.clarity.ms)
  # are covered below. PostHog is deferred (Task 15 decision) — if/when it
  # ships, add its host (https://*.posthog.com or the EU/self-host domain)
  # to BOTH script-src and connect-src here.
  # RB2B (visitor identification, added 2026-07-16): hosts extracted from the
  # deobfuscated tag itself (RB2B publishes no CSP list). Loader script on
  # ddwl4m2hdecbv.cloudfront.net with S3 fallbacks; collector on a dynamic
  # *.execute-api.us-west-2.amazonaws.com subdomain; identity partners
  # LiveIntent (*.liadm.com) + usbrowserspeed; geo via pro.ip-api.com;
  # config via alocdn.com. Re-extract if RB2B silently stops reporting.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://*.clarity.ms https://ddwl4m2hdecbv.cloudfront.net https://b2bjsstore.s3.us-west-2.amazonaws.com https://s3-us-west-2.amazonaws.com https://*.liadm.com https://a.usbrowserspeed.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://www.google-analytics.com https://*.clarity.ms https://c.bing.com https://*.liadm.com https://a.usbrowserspeed.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://tidycal.com https://*.clarity.ms https://app.rb2b.com https://*.execute-api.us-west-2.amazonaws.com https://pro.ip-api.com https://a.usbrowserspeed.com https://alocdn.com https://*.liadm.com https://ddwl4m2hdecbv.cloudfront.net https://b2bjsstore.s3.us-west-2.amazonaws.com https://s3-us-west-2.amazonaws.com; frame-src https://tidycal.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
</IfModule>

# Long-cache ONLY content-hashed build assets (Astro emits `name.<hash>.ext`
# under /_astro/ — the hash changes when content changes, so immutable is safe).
# Non-hashed public assets (og-image.png, image.webp, favicon.ico) keep their
# filenames when updated, so immutable would pin stale versions for a year —
# they get a day instead (final-review finding, 2026-07-13).
# NOTE: LiteSpeed doesn't support `Header setifempty` (it emitted a literal
# "setifempty:" response header in production). Ordering does the work
# instead: the generic image rule runs first, then the hashed-asset rule
# overrides it for hashed files — the last matching `Header set` wins.
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|svg|ico|jpg|jpeg)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
  <FilesMatch "\.[A-Za-z0-9_-]{8,}\.(js|css|woff2|webp|png|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>
